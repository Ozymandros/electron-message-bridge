{
  "name": "@ozymandros/electron-message-bridge",
  "version": "0.4.5",
  "description": "A small, typed, zero-boilerplate Electron IPC helper. Full end-to-end type inference across main, preload, and renderer.",
  "keywords": [
    "electron",
    "ipc",
    "typescript",
    "contextBridge",
    "typed",
    "ipcMain",
    "ipcRenderer"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ozymandros/electron-message-bridge.git"
  },
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "import": "./dist/preload.mjs",
      "require": "./dist/preload.cjs"
    },
    "./integrations": {
      "types": "./dist/integrations.d.ts",
      "import": "./dist/integrations.mjs",
      "require": "./dist/integrations.cjs"
    },
    "./menus": {
      "types": "./dist/menus.d.ts",
      "import": "./dist/menus.mjs",
      "require": "./dist/menus.cjs"
    },
    "./appkit": {
      "types": "./dist/appkit.d.ts",
      "import": "./dist/appkit.mjs",
      "require": "./dist/appkit.cjs"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle.d.ts",
      "import": "./dist/lifecycle.mjs",
      "require": "./dist/lifecycle.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins.d.ts",
      "import": "./dist/plugins.mjs",
      "require": "./dist/plugins.cjs"
    },
    "./plugins/window-state": {
      "types": "./dist/plugins/window-state.d.ts",
      "import": "./dist/plugins/window-state.mjs",
      "require": "./dist/plugins/window-state.cjs"
    },
    "./plugins/diagnostics": {
      "types": "./dist/plugins/diagnostics.d.ts",
      "import": "./dist/plugins/diagnostics.mjs",
      "require": "./dist/plugins/diagnostics.cjs"
    },
    "./plugins/updater": {
      "types": "./dist/plugins/updater.d.ts",
      "import": "./dist/plugins/updater.mjs",
      "require": "./dist/plugins/updater.cjs"
    },
    "./boundary": {
      "types": "./dist/boundary.d.ts",
      "import": "./dist/boundary.mjs",
      "require": "./dist/boundary.cjs"
    },
    "./adapters/loader": {
      "types": "./dist/adapters/loader.d.ts",
      "import": "./dist/adapters/loader.mjs",
      "require": "./dist/adapters/loader.cjs"
    },
    "./adapters/assemblyscript": {
      "types": "./dist/adapters/assemblyscript.d.ts",
      "import": "./dist/adapters/assemblyscript.mjs",
      "require": "./dist/adapters/assemblyscript.cjs"
    },
    "./adapters/named-pipe": {
      "types": "./dist/adapters/named-pipe.d.ts",
      "import": "./dist/adapters/named-pipe.mjs",
      "require": "./dist/adapters/named-pipe.cjs"
    },
    "./adapters/grpc": {
      "types": "./dist/adapters/grpc.d.ts",
      "import": "./dist/adapters/grpc.mjs",
      "require": "./dist/adapters/grpc.cjs"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "import": "./dist/transport.mjs",
      "require": "./dist/transport.cjs"
    },
    "./adapters/stdio": {
      "types": "./dist/adapters/stdio.d.ts",
      "import": "./dist/adapters/stdio.mjs",
      "require": "./dist/adapters/stdio.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "build:all": "pnpm run build && pnpm -r --filter \"./packages/*\" run build",
    "dev": "tsup --watch",
    "docker:mock:build": "docker build -t ozymandros/electron-message-bridge/mock-backend:local docker/mock-backend",
    "docker:mock:up": "docker compose -f docker-compose.integration.yml up -d --build",
    "docker:mock:down": "docker compose -f docker-compose.integration.yml down -v",
    "docker:mock:logs": "docker compose -f docker-compose.integration.yml logs -f mock-backend",
    "lint": "eslint src/ tests/",
    "check": "eslint src/ tests/ && tsc --noEmit -p tsconfig.typecheck.json && vitest --typecheck run",
    "check:packages": "pnpm run typecheck:refs",
    "check:all": "pnpm run check && pnpm run check:packages && pnpm run test:types && pnpm run test",
    "check:all:coverage": "pnpm run check && pnpm run check:packages && pnpm run test:types && pnpm run test:coverage",
    "test": "vitest run",
    "test:all": "pnpm -r run test",
    "test:api-surface": "vitest run tests/api-surface.test.ts",
    "test:integration": "vitest run tests/integration/mock-backend.integration.test.ts",
    "test:integration:docker": "pnpm run docker:mock:up && pnpm run test:integration",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "typecheck:refs": "tsc -b --pretty false",
    "clean": "rimraf dist",
    "pack:all": "pnpm run build && pnpm --dir packages/adapter-assemblyscript run build && pnpm pack && pnpm --dir packages/adapter-assemblyscript pack --pack-destination ../..",
    "publish:adapters": "pnpm -r --filter \"./packages/adapter-*\" publish --access public --no-git-checks --registry=https://registry.npmjs.org",
    "publish:adapters:ci": "pnpm -r --filter \"./packages/adapter-*\" publish --access public --no-git-checks --provenance --registry=https://registry.npmjs.org",
    "publish:core": "pnpm publish --access public --no-git-checks --registry=https://registry.npmjs.org",
    "publish:core:ci": "pnpm publish --access public --no-git-checks --provenance --registry=https://registry.npmjs.org",
    "publish:all": "pnpm install --no-frozen-lockfile && pnpm run build:all && pnpm -r --filter \"./packages/*\" publish --access public --no-git-checks --registry=https://registry.npmjs.org && pnpm run publish:core",
    "publish:adapters:dry-run": "pnpm -r --filter \"./packages/adapter-*\" publish --dry-run --access public --no-git-checks --registry=https://registry.npmjs.org",
    "publish:core:dry-run": "pnpm publish --dry-run --access public --no-git-checks --registry=https://registry.npmjs.org",
    "publish:all:dry-run": "pnpm install --no-frozen-lockfile && pnpm run build:all && pnpm -r --filter \"./packages/*\" publish --dry-run --access public --no-git-checks --registry=https://registry.npmjs.org && pnpm run publish:core:dry-run"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^1.6.1",
    "electron": "^32.0.0",
    "eslint": "^10.2.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
