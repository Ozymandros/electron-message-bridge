{
  "name": "electron-ipc-helper",
  "version": "0.1.0",
  "description": "A small, typed, zero-boilerplate Electron IPC helper. Full end-to-end type inference across main, preload, and renderer.",
  "keywords": [
    "electron",
    "ipc",
    "typescript",
    "contextBridge",
    "typed",
    "ipcMain",
    "ipcRenderer"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.10.0",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "import": "./dist/preload.mjs",
      "require": "./dist/preload.cjs"
    },
    "./integrations": {
      "types": "./dist/integrations.d.ts",
      "import": "./dist/integrations.mjs",
      "require": "./dist/integrations.cjs"
    },
    "./menus": {
      "types": "./dist/menus.d.ts",
      "import": "./dist/menus.mjs",
      "require": "./dist/menus.cjs"
    },
    "./appkit": {
      "types": "./dist/appkit.d.ts",
      "import": "./dist/appkit.mjs",
      "require": "./dist/appkit.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src/ tests/",
    "check": "eslint src/ tests/ && tsc --noEmit -p tsconfig.typecheck.json && vitest --typecheck run",
    "test": "vitest run",
    "check:all": "pnpm run check && pnpm run test:types && pnpm run test",
    "check:all:coverage": "pnpm run check && pnpm run test:types && pnpm run test:coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:types": "vitest --typecheck run",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "clean": "rimraf dist"
  },
  "peerDependencies": {
    "electron": ">=20.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^1.6.1",
    "electron": "^32.0.0",
    "eslint": "^10.2.0",
    "rimraf": "^5.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
